# =============================================================================
# Railway / production
# =============================================================================
# In Railway: New Project → Deploy from GitHub → set Root Directory to `backend` (if needed).
# Variables (Railway dashboard → Variables):
#   MONGO_URI      — MongoDB Atlas connection string (or Railway MongoDB plugin URL)
#   JWT_SECRET     — long random string (e.g. openssl rand -hex 32)
#   OPENAI_API_KEY — required for AI features
#   NODE_ENV       — production
#
# Railway sets PORT automatically — do not hardcode it in code (server uses process.env.PORT).

NODE_ENV=production

# HTTP server (Railway injects PORT; local default 3000)
PORT=3000
HOST=0.0.0.0

# Required: MongoDB (Atlas SRV or local)
MONGO_URI=mongodb://127.0.0.1:27017/reelboost_ai
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/reelboost_ai?retryWrites=true&w=majority

# Optional: if mongodb+srv fails with querySrv ECONNREFUSED on some networks:
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Required: signing JWTs (auth)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Required for captions / ideas / etc.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: restrict browser CORS to specific origins (comma-separated). If unset, reflects request Origin (mobile apps OK).
# CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com

# Admin routes (optional). Min 8 chars if set.
# ADMIN_API_KEY=

# --- Forgot password (Gmail + Nodemailer) — Railway Variables ---
# 1) PUBLIC_BASE_URL = your API’s public https URL (no trailing slash), e.g.:
#    https://reelboost-production.up.railway.app
#    Emails use: {PUBLIC_BASE_URL}/api/auth/reset-password-page?token=...
#
# 2) Gmail — use an App Password (16 characters), NOT your normal password:
#    Google Account → Security → 2-Step Verification → App passwords → create → copy.
#    Spaces in EMAIL_PASS are stripped automatically.
#
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=abcd efgh ijkl mnop
# EMAIL_FROM=ReelBoost <you@gmail.com>
#
# Optional: run SMTP verify() before each send (slower; helps debug auth errors on Railway)
# MAIL_VERIFY_BEFORE_SEND=true
#
# Optional: if email send fails, include devResetLink + devResetToken in JSON (INSECURE). Must be exactly "true".
# EXPOSE_RESET_LINK_ON_MAIL_FAILURE=true
#
# Gmail port: 587 (default, STARTTLS) or 465 (SSL). Rarely needed:
# SMTP_PORT=587
#
# Or use custom SMTP: SMTP_HOST, SMTP_USER, SMTP_PASS, MAIL_FROM or EMAIL_FROM
# PASSWORD_RESET_BASE_URL=https://your-service.up.railway.app/api/auth/reset-password-page

# Ad reward limits (optional)
# MAX_AD_REWARDS_PER_DAY=5
# SUSPICIOUS_INVALID_AD_THRESHOLD=5
# REWARD_COOLDOWN_SECONDS=30
