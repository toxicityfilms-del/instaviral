PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/reelboost_ai

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Razorpay (required for premium checkout)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Premium product (order checkout grants this many days)
PREMIUM_AMOUNT_PAISE=49900
PREMIUM_DAYS=30

# Firebase Admin — server-side FCM (trending push notifications)
# Download service account JSON from Firebase Console → Project settings → Service accounts
# FIREBASE_SERVICE_ACCOUNT_JSON_PATH=./firebase-service-account.json

# Scheduled trending digest (cron). Example: every day at 10:00 Asia/Kolkata
# TREND_ALERT_CRON=0 10 * * *
# TREND_ALERT_TZ=Asia/Kolkata

# Optional: POST /admin/trending-digest with header X-Admin-Secret
# ADMIN_SECRET=
